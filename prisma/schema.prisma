generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  passwordHash  String
  email         String  @unique
  emailVerified Boolean @default(false)

  cars     Car[]
  Services Service[]

  updatedAt DateTime @updatedAt
  joinedAt  DateTime @default(now())

  @@map("Users")
}

model Car {
  id      String @id @default(uuid())
  name    String
  mileage Int

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  Services Service[]

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("Cars")
}

enum ServiceType {
  Recurrent
  NonRecurrent

  @@map("ServicesType")
}

model Service {
  id              String      @id @default(uuid())
  mileage         Int
  mileageInterval Int?
  cost            Float
  title           String
  details         String?
  date            DateTime
  type            ServiceType

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  carId String
  car   Car    @relation(fields: [carId], references: [id])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("Services")
}

enum OtpPurpose {
  signup
  forgot_password
}

model EmailOtp {
  id String @id @default(uuid())

  email        String
  code         String
  expiresAt    DateTime
  lastSentAt   DateTime
  consumedAt   DateTime?
  purpose      OtpPurpose
  sendCount    Int        @default(1)
  attemptCount Int        @default(0)

  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("EmailOtps")
}
